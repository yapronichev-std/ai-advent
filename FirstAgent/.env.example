OPENROUTER_API_KEY=your_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_SUMMARY_INTERVAL=60

# mcp-search — поиск через OpenRouter (отдельный API-ключ не нужен)
# Модель с веб-доступом. Примеры:
#   perplexity/sonar-pro          (по умолчанию, встроенный поиск)
#   openai/gpt-4o:online          (gpt-4o + web-плагин OpenRouter)
#   anthropic/claude-3.5-sonnet:online
SEARCH_MODEL=perplexity/sonar-pro

# Пайплайн диаграмм — fallback-модель при ошибке drawio
DRAWIO_FALLBACK_MODEL=openai/gpt-4o
